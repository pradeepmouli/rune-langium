modules = ["nodejs-22", "bash", "web", "python-3.11"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Studio Dev Server"

[[workflows.workflow]]
name = "Studio Dev Server"
author = "agent"
mode = "sequential"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm install -g pnpm@11.5.0 --quiet 2>/dev/null; pnpm install && pnpm --filter @rune-langium/core build && pnpm --filter @rune-langium/curated-schema build && pnpm --filter @rune-langium/codegen-legacy build && pnpm --filter @rune-langium/codegen build && pnpm --filter @rune-langium/design-tokens build && pnpm --filter @rune-langium/design-system build && pnpm --filter @rune-langium/visual-editor build && pnpm --filter @rune-langium/lsp-server build && STUDIO_DEV_PORT=5000 pnpm --filter @rune-langium/studio dev"
waitForPort = 5000

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 5174
externalPort = 3003
exposeLocalhost = true

[deployment]
deploymentTarget = "static"
build = ["bash", "-c", "npm install -g pnpm@11.5.0 && pnpm install && pnpm --filter @rune-langium/core build && pnpm --filter @rune-langium/visual-editor build && pnpm --filter @rune-langium/lsp-server build && pnpm --filter @rune-langium/studio build"]
publicDir = "apps/studio/dist"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000
