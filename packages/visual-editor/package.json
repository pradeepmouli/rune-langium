{
  "name": "@rune-langium/visual-editor",
  "version": "0.1.0",
  "description": "ReactFlow-based visual editor component library for Rune DSL type hierarchies",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./components": {
      "types": "./dist/components.d.ts",
      "default": "./dist/components.js"
    }
  },
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "tsgo -b && cp src/styles.css dist/styles.css",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "dev": "tsgo -b --watch",
    "lint": "oxlint .",
    "generate:schemas": "langium-zod generate --config ../core/langium-config.json --out src/generated/zod-schemas.ts --strip-internals --projection form-surfaces.json --cross-ref-validation --conformance --ast-types ../core/src/generated/ast.ts --conformance-out src/generated/zod-schemas.conformance.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsgo --noEmit"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@hookform/resolvers": "^5.2.2",
    "@rune-langium/core": "workspace:*",
    "@rune-langium/design-system": "workspace:*",
    "@tanstack/react-virtual": "^3.13.24",
    "@xyflow/react": "^12.10.2",
    "@zod-to-form/core": "^0.8.0",
    "@zod-to-form/react": "^0.8.0",
    "lucide-react": "^1.11.0",
    "react-hook-form": "^7.74.0",
    "zod": "^4.3.6",
    "zundo": "^2.3.0",
    "zustand": "^5.0.12"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@zod-to-form/vite": "^0.3.1",
    "jsdom": "^29.1.0",
    "langium-zod": "^0.5.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pradeepmouli/rune-langium.git",
    "directory": "packages/visual-editor"
  },
  "keywords": [
    "rune",
    "rosetta",
    "dsl",
    "visual-editor",
    "reactflow",
    "graph",
    "type-hierarchy"
  ],
  "author": "Pradeep Mouli <pmouli@mac.com> (https://github.com/pradeepmouli)",
  "publishConfig": {
    "access": "public"
  }
}
