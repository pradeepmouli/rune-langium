{
  "name": "@rune-langium/visual-editor",
  "version": "0.2.0",
  "description": "ReactFlow-based visual editor component library for Rune DSL type hierarchies",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./styles.css": "./src/styles.css",
    "./components": "./src/components.ts"
  },
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "tsgo -b && cp src/styles.css dist/styles.css",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "dev": "tsgo -b --watch",
    "lint": "pnpm run lint:js && pnpm run lint:css",
    "lint:js": "oxlint .",
    "lint:css": "stylelint 'src/**/*.css'",
    "generate:schemas": "langium-zod generate --config ../core/langium-config.json --out src/generated/zod-schemas.ts --strip-internals --projection form-surfaces.json --cross-ref-validation --conformance --ast-types ../core/src/generated/ast.ts --conformance-out src/generated/zod-schemas.conformance.ts && oxfmt src/generated/zod-schemas.ts src/generated/zod-schemas.conformance.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsgo --noEmit"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@hookform/resolvers": "^5.4.0",
    "@rune-langium/codegen": "workspace:*",
    "@rune-langium/core": "workspace:*",
    "@rune-langium/design-system": "workspace:*",
    "@tanstack/react-virtual": "^3.14.3",
    "@xyflow/react": "^12.11.1",
    "@zod-to-form/core": "^0.9.1",
    "@zod-to-form/react": "^0.9.2",
    "elkjs": "^0.11.1",
    "lucide-react": "^1.21.0",
    "mutative": "^1.3.0",
    "react-hook-form": "^7.80.0",
    "zod": "^4.4.3",
    "zundo": "^2.3.0",
    "zustand": "^5.0.14"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@zod-to-form/vite": "^0.4.4",
    "jsdom": "^29.1.1",
    "langium-zod": "0.10.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pradeepmouli/rune-langium.git",
    "directory": "packages/visual-editor"
  },
  "keywords": [
    "rune",
    "rosetta",
    "dsl",
    "visual-editor",
    "reactflow",
    "graph",
    "type-hierarchy"
  ],
  "author": "Pradeep Mouli <pmouli@mac.com> (https://github.com/pradeepmouli)",
  "publishConfig": {
    "access": "public"
  }
}
