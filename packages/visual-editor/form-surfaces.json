{
  "_comment": [
    "Form-surface projection config for langium-zod generate --projection.",
    "Only form-relevant fields are included per type — Langium internals are",
    "stripped via --strip-internals CLI flag.",
    "",
    "Expected conformance assertions (T008 pre-generation spec):",
    "  RosettaEnumeration → RosettaEnumerationSchema: fields name, parent",
    "    cross-ref factory: createRosettaEnumerationSchema(refs?) — parent ref field",
    "  Data              → DataSchema: fields name, superType, attributes",
    "    cross-ref factory: createDataSchema(refs?) — superType ref field",
    "  Attribute         → AttributeSchema: fields name, typeCall, card",
    "    no cross-ref factory (typeCall and card are value types)",
    "  RosettaFunction   → RosettaFunctionSchema: fields name, inputs, output",
    "    no cross-ref factory",
    "  Choice            → ChoiceSchema: fields name, attributes",
    "    no cross-ref factory",
    "",
    "Confirmed field names from grammar (rune-dsl.langium) + ast.ts:",
    "  RosettaEnumeration.parent  — cross-reference (NOT superEnum)",
    "  Data.superType             — cross-reference",
    "  Data.attributes            — Attribute[]",
    "  Attribute.typeCall         — TypeCallSimple",
    "  Attribute.card             — RosettaCardinality",
    "  RosettaFunction.inputs     — Attribute[] (NOT parameters)",
    "  RosettaFunction.output     — Attribute? (NOT outputType)",
    "  Choice.attributes          — ChoiceOption[] (NOT options)"
  ],
  "defaults": {
    "strip": ["$container", "$document", "$cstNode", "$containerProperty", "$containerIndex"]
  },
  "types": {
    "RosettaEnumeration": {
      "fields": ["name", "parent", "enumValues"]
    },
    "Data": {
      "fields": ["name", "superType", "attributes"]
    },
    "Attribute": {
      "fields": ["name", "typeCall", "card"]
    },
    "RosettaFunction": {
      "fields": ["name", "inputs", "output"]
    },
    "Choice": {
      "fields": ["name", "attributes"]
    },
    "RosettaTypeAlias": {
      "fields": ["name", "typeCall", "definition"]
    }
  }
}
