{
  "name": "@rune-langium/lsp-server",
  "version": "0.1.0",
  "description": "LSP server for the Rune DSL, powered by Langium and @lspeasy/server",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "rune-lsp-server": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "predev": "lsof -ti:3001 2>/dev/null | xargs kill -9 2>/dev/null; exit 0",
    "dev": "tsc -b && node --watch-path=dist dist/cli.js",
    "lint": "oxlint .",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@lspeasy/core": "^2.3.0",
    "@lspeasy/server": "^4.1.2",
    "@rune-langium/core": "workspace:*",
    "langium": "^4.3.0",
    "vscode-languageserver": "~10.0.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@lspeasy/client": "^3.1.5",
    "@types/ws": "^8.18.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "license": "MIT",
  "homepage": "https://github.com/pradeepmouli/rune-langium/tree/master/packages/lsp-server",
  "bugs": {
    "url": "https://github.com/pradeepmouli/rune-langium/issues"
  },
  "keywords": [
    "rune",
    "rosetta",
    "dsl",
    "langium",
    "lsp",
    "language-server",
    "cdm"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/pradeepmouli/rune-langium.git",
    "directory": "packages/lsp-server"
  },
  "author": "Pradeep Mouli <pmouli@mac.com> (https://github.com/pradeepmouli)",
  "publishConfig": {
    "access": "public"
  }
}
