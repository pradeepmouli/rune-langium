{
  "name": "@rune-langium/cli",
  "version": "0.1.0",
  "description": "CLI tools for the Rune DSL (Langium-based parser)",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/pradeepmouli/rune-langium/tree/master/packages/cli",
  "repository": {
    "type": "git",
    "url": "https://github.com/pradeepmouli/rune-langium.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/pradeepmouli/rune-langium/issues"
  },
  "keywords": [
    "rune",
    "rosetta",
    "dsl",
    "langium",
    "cli",
    "cdm",
    "parser"
  ],
  "bin": {
    "rune-dsl": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsgo -b",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "type-check": "tsgo --noEmit"
  },
  "dependencies": {
    "@rune-langium/codegen-legacy": "workspace:*",
    "@rune-langium/core": "workspace:*",
    "commander": "^14.0.3",
    "langium": "^4.2.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  },
  "author": "Pradeep Mouli <pmouli@mac.com> (https://github.com/pradeepmouli)",
  "publishConfig": {
    "access": "public"
  }
}
