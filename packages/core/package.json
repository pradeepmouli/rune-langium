{
  "name": "@rune-langium/core",
  "version": "0.1.0",
  "description": "Langium-based parser and typed AST for the Rune DSL (.rosetta files)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./zod-schemas": {
      "types": "./dist/generated/zod-schemas.d.ts",
      "default": "./dist/generated/zod-schemas.js"
    }
  },
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsgo -b",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "dev": "tsgo -b --watch",
    "generate": "langium generate && langium-zod generate",
    "generate:zod": "langium-zod generate",
    "lint": "oxlint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsgo --noEmit",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "langium": "^4.2.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "langium-cli": "^4.2.0",
    "langium-zod": "^0.5.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pradeepmouli/rune-langium.git",
    "directory": "packages/core"
  },
  "keywords": [
    "rune",
    "rosetta",
    "dsl",
    "langium",
    "parser",
    "ast",
    "cdm",
    "isda"
  ]
}
