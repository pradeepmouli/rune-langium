{
  "$schema": "./tokens.schema.json",
  "version": "0.1.0",
  "_comment": "T022 will replace these placeholders with the actual values Studio currently uses; this scaffold just proves the structure compiles end-to-end.",
  "color": {
    "surface": { "1": "#ffffff", "2": "#f8fafc", "3": "#f1f5f9" },
    "foreground": { "primary": "#0f172a", "secondary": "#475569", "muted": "#94a3b8" },
    "accent": { "base": "#6366f1", "hover": "#4f46e5", "subtle": "#eef2ff" },
    "danger": { "base": "#dc2626", "hover": "#b91c1c" },
    "warning": { "base": "#d97706", "hover": "#b45309" },
    "success": { "base": "#16a34a", "hover": "#15803d" },
    "border": { "subtle": "#e2e8f0", "default": "#cbd5e1", "strong": "#94a3b8" }
  },
  "color_dark": {
    "surface": { "1": "#0f172a", "2": "#1e293b", "3": "#334155" },
    "foreground": { "primary": "#f8fafc", "secondary": "#cbd5e1", "muted": "#64748b" },
    "accent": { "base": "#818cf8", "hover": "#a5b4fc", "subtle": "#1e1b4b" },
    "danger": { "base": "#f87171", "hover": "#fca5a5" },
    "warning": { "base": "#fbbf24", "hover": "#fcd34d" },
    "success": { "base": "#4ade80", "hover": "#86efac" },
    "border": { "subtle": "#1e293b", "default": "#334155", "strong": "#475569" }
  },
  "font": {
    "family": {
      "sans": "Inter, system-ui, -apple-system, sans-serif",
      "mono": "ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace"
    },
    "size": {
      "xs": "0.75rem",
      "sm": "0.875rem",
      "base": "1rem",
      "lg": "1.125rem",
      "xl": "1.25rem",
      "2xl": "1.5rem",
      "3xl": "1.875rem"
    },
    "weight": { "regular": "400", "medium": "500", "semibold": "600", "bold": "700" }
  },
  "line-height": { "tight": "1.25", "normal": "1.5", "relaxed": "1.75" },
  "spacing": {
    "0": "0",
    "1": "0.25rem",
    "2": "0.5rem",
    "3": "0.75rem",
    "4": "1rem",
    "6": "1.5rem",
    "8": "2rem",
    "12": "3rem",
    "16": "4rem",
    "24": "6rem",
    "32": "8rem"
  },
  "radius": { "sm": "0.25rem", "md": "0.5rem", "lg": "0.75rem", "full": "9999px" },
  "shadow": {
    "sm": "0 1px 2px 0 rgb(0 0 0 / 0.05)",
    "md": "0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1)",
    "lg": "0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1)"
  },
  "motion": {
    "duration": { "fast": "120ms", "base": "200ms", "slow": "320ms" },
    "easing": {
      "standard": "cubic-bezier(0.4, 0, 0.2, 1)",
      "emphasis": "cubic-bezier(0.2, 0, 0, 1)"
    }
  },
  "z-index": { "base": "0", "popover": "100", "modal": "200", "toast": "300" }
}
