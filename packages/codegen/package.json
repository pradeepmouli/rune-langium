{
  "name": "@rune-langium/codegen",
  "version": "0.1.0",
  "description": "Code generators and preview-schema utilities for Rune DSL models",
  "license": "MIT",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "bin": {
    "rune-codegen": "./dist/bin/rune-codegen.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsgo -b",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsgo --noEmit"
  },
  "dependencies": {
    "@rune-langium/core": "workspace:*",
    "commander": "^14.0.3",
    "exceljs": "^4.4.0",
    "langium": "^4.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "node-sql-parser": "^5.4.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7",
    "zod": "^4.4.3"
  },
  "homepage": "https://github.com/pradeepmouli/rune-langium/tree/master/packages/codegen",
  "repository": {
    "type": "git",
    "url": "https://github.com/pradeepmouli/rune-langium.git",
    "directory": "packages/codegen"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "Pradeep Mouli <pmouli@mac.com> (https://github.com/pradeepmouli)",
  "keywords": [
    "rune",
    "langium",
    "codegen",
    "zod",
    "json-schema",
    "typescript",
    "cdm"
  ]
}
