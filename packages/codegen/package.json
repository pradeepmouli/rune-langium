{
  "name": "@rune-langium/codegen",
  "version": "0.1.0",
  "description": "Code generation service and types for Rune DSL models via rosetta-code-generators",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "default": "./dist/node.js"
    },
    "./serve": {
      "default": "./dist/serve.js"
    }
  },
  "bin": {
    "codegen-serve": "./dist/serve.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsgo -b",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "type-check": "tsgo --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.3"
  },
  "license": "MIT",
  "homepage": "https://github.com/pradeepmouli/rune-langium/tree/master/packages/codegen",
  "repository": {
    "type": "git",
    "url": "https://github.com/pradeepmouli/rune-langium.git",
    "directory": "packages/codegen"
  },
  "bugs": {
    "url": "https://github.com/pradeepmouli/rune-langium/issues"
  },
  "keywords": ["rune", "rosetta", "dsl", "codegen", "code-generation", "cdm"]
}
