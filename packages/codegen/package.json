{
  "name": "@rune-langium/codegen",
  "version": "0.1.0",
  "description": "Code generation service and types for Rune DSL models via rosetta-code-generators",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsgo -b",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "type-check": "tsgo --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "license": "Apache-2.0"
}
