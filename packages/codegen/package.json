{
  "name": "@rune-langium/codegen",
  "version": "0.1.0",
  "description": "Code generators and preview-schema utilities for Rune DSL models",
  "license": "MIT",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./export": {
      "types": "./dist/src/export.d.ts",
      "default": "./dist/src/export.js"
    },
    "./import": {
      "types": "./dist/src/import/index.d.ts",
      "default": "./dist/src/import/index.js"
    },
    "./rosetta": {
      "types": "./dist/src/rosetta.d.ts",
      "default": "./dist/src/rosetta.js"
    }
  },
  "bin": {
    "rune-codegen": "./dist/bin/rune-codegen.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "generate:sql-node-types": "node scripts/generate-tree-sitter-node-types.mjs --input node_modules/@l1xnan/tree-sitter-sql/src/node-types.json --output src/import/sources/generated/sql-node-types.ts --prefix Sql && oxfmt src/import/sources/generated/sql-node-types.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json"
  },
  "dependencies": {
    "@l1xnan/tree-sitter-sql": "0.4.7",
    "@rune-langium/core": "workspace:*",
    "commander": "^15.0.0",
    "exceljs": "^4.4.0",
    "fast-xml-parser": "^5.9.3",
    "langium": "^4.3.0",
    "web-tree-sitter": "^0.26.10",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/json-schema": "^7.0.15",
    "@types/node": "^26.0.1",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "node-sql-parser": "^5.4.0",
    "openapi-types": "^12.1.3",
    "typescript": "^7.0.2",
    "typescript-classic": "npm:typescript@6.0.3",
    "vitest": "^4.1.9",
    "zod": "^4.4.3"
  },
  "homepage": "https://github.com/pradeepmouli/rune-langium/tree/master/packages/codegen",
  "repository": {
    "type": "git",
    "url": "https://github.com/pradeepmouli/rune-langium.git",
    "directory": "packages/codegen"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "Pradeep Mouli <pmouli@mac.com> (https://github.com/pradeepmouli)",
  "keywords": [
    "rune",
    "langium",
    "codegen",
    "zod",
    "json-schema",
    "typescript",
    "cdm"
  ]
}
