{
  "name": "rune-langium",
  "version": "0.1.0",
  "private": true,
  "description": "Langium port for Rune DSL tooling",
  "type": "module",
  "author": "Pradeep Mouli <pmouli@mac.com> (https://github.com/pradeepmouli)",
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://www.daikonic.dev/rune-studio/",
  "repository": {
    "type": "git",
    "url": "https://github.com/pradeepmouli/rune-langium.git"
  },
  "bugs": {
    "url": "https://github.com/pradeepmouli/rune-langium/issues"
  },
  "keywords": [
    "rune",
    "rosetta",
    "dsl",
    "langium",
    "cdm",
    "isda",
    "drr",
    "finos",
    "language-server",
    "lsp",
    "visual-editor",
    "reactflow"
  ],
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "pnpm -r run build",
    "build:ci": "pnpm -r --filter=!@rune-langium/docs --filter=!rune-langium run build",
    "build:core": "pnpm --filter @rune-langium/core build",
    "build:visual-editor": "pnpm --filter @rune-langium/visual-editor build",
    "build:studio": "pnpm --filter @rune-langium/studio build",
    "build:cloudflare": "pnpm --filter @rune-langium/docs run build:combined",
    "build:container": "pnpm --filter @rune-langium/codegen-container run build",
    "deploy:worker": "pnpm --filter @rune-langium/codegen-worker run deploy",
    "deploy:curated-mirror": "pnpm --filter @rune-langium/curated-mirror-worker run deploy",
    "deploy:container": "pnpm --filter @rune-langium/codegen-container run publish",
    "clean": "pnpm -r run clean && rm -rf node_modules/.cache",
    "clean:all": "pnpm -r exec rm -rf dist node_modules && rm -rf node_modules",
    "dev": "pnpm --filter @rune-langium/studio dev:full",
    "dev:lsp": "pnpm --filter @rune-langium/lsp-server dev",
    "predev:studio": "pnpm --filter @rune-langium/studio dev:cleanup",
    "dev:studio": "pnpm --filter @rune-langium/studio dev",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "fresh": "pnpm clean:all && pnpm install",
    "generate": "pnpm --filter @rune-langium/core run generate",
    "lint": "oxlint . && pnpm -r --if-present run lint:css",
    "lint:fix": "oxlint --fix .",
    "test": "pnpm -r run test",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "type-check": "pnpm -r run type-check",
    "ui:add": "pnpm --filter @rune-langium/design-system exec shadcn add",
    "prepare": "simple-git-hooks",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "pnpm run build && changeset publish",
    "codegen:build-deps": "cd ../rosetta-code-generators && JAVA_HOME=${JAVA21_HOME:-/opt/homebrew/opt/openjdk@21/libexec/openjdk.jdk/Contents/Home} mvn package -DskipTests -pl default-cdm-generators -am",
    "codegen:build": "packages/codegen/server/build.sh",
    "codegen:test": "packages/codegen/server/target/codegen-cli.sh --list-languages",
    "codegen:start": "node packages/codegen/dist/serve.js",
    "docs:dev": "pnpm --filter @rune-langium/docs dev",
    "docs:build": "pnpm --filter @rune-langium/docs build",
    "verify:prod": "bash scripts/verify-production.sh",
    "verify:prod:ui": "pnpm --filter @rune-langium/studio run test:prod-smoke",
    "verify:prod:all": "pnpm run verify:prod && pnpm run verify:prod:ui"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@to-skills/cli": "^0.3.14",
    "@to-skills/vitepress": "^0.2.26",
    "@types/node": "^26.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "concurrently": "^10.0.3",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.71.0",
    "simple-git-hooks": "^2.13.1",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typedoc-plugin-to-skills": "^1.3.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.5.0",
  "dependencies": {
    "@lspeasy/client": "^3.1.2",
    "@lspeasy/core": "^2.3.0",
    "camelcase": "^9.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc}": "oxfmt"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged",
    "pre-push": "pnpm run type-check"
  }
}
