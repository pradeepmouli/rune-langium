{
  "chat.promptFilesRecommendations": {
    "speckit.constitution": true,
    "speckit.specify": true,
    "speckit.plan": true,
    "speckit.tasks": true,
    "speckit.implement": true
  },
  "chat.tools.terminal.autoApprove": {
    ".specify/scripts/bash/": true,
    ".specify/scripts/powershell/": true
  },
  "css.lint.unknownAtRules": "ignore",
  "scss.lint.unknownAtRules": "ignore",
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "tailwindCSS.experimental.configFile": {
    "apps/studio/src/app.css": "{apps/studio/src/**,packages/design-system/src/**,packages/visual-editor/src/**}"
  },
  "tailwindCSS.includeLanguages": {
    "typescript": "javascript",
    "typescriptreact": "javascript"
  },
  "tailwindCSS.classFunctions": [
    "cn",
    "clsx",
    "cva",
    "cx",
    "twMerge"
  ],
  "builder.serverUrl": "http://localhost:8788",
  "builder.command": "",
  "builder.runDevServer": false,
  "builder.autoDetectDevServer": true,
  "builder.launchType": "editor"
}
