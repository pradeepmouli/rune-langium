{
  "entryPointStrategy": "packages",
  "entryPoints": ["packages/*"],
  "out": "docs/api",
  "plugin": ["typedoc-plugin-markdown", "typedoc-plugin-to-skills"],
  "skipErrorChecking": true,
  "includeVersion": true,
  "readme": "none",
  "treatWarningsAsErrors": false,
  "excludePrivate": true,
  "excludeInternal": true,
  "hideGenerator": true
}
