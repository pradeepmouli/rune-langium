{
  "name": "@rune-langium/curated-mirror-worker",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare Worker (Cron-triggered) that mirrors curated Rune model archives (CDM, FpML, rune-dsl) into R2 nightly. Studio fetches from the mirror instead of cloning at runtime (feature 012-studio-workspace-ux).",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "seed:local": "NODE_OPTIONS='--max-old-space-size=4096' tsx scripts/seed-local-curated-mirror.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsgo --noEmit"
  },
  "dependencies": {
    "@rune-langium/core": "workspace:*",
    "@rune-langium/curated-schema": "workspace:*",
    "langium": "^4.2.4",
    "pako": "^2.1.0",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260525.1",
    "miniflare": "^4.20260520.0",
    "vitest": "^4.1.7",
    "wrangler": "^4.93.1"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "license": "FSL-1.1-ALv2",
  "author": "Pradeep Mouli <pmouli@mac.com> (https://github.com/pradeepmouli)"
}
