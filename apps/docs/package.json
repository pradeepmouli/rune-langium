{
  "name": "@rune-langium/docs",
  "version": "0.0.0",
  "private": true,
  "description": "Documentation site for rune-langium",
  "scripts": {
    "docs:api": "typedoc --options .vitepress/typedoc.json",
    "dev": "pnpm run docs:api && vitepress dev",
    "build": "pnpm run docs:api && vitepress build",
    "build:combined": "node scripts/build-combined.mjs",
    "preview": "vitepress preview"
  },
  "dependencies": {
    "@rune-langium/design-tokens": "workspace:*"
  },
  "devDependencies": {
    "vitepress": "2.0.0-alpha.17",
    "typedoc": "0.28.17",
    "typedoc-plugin-markdown": "^4.11.0",
    "typedoc-vitepress-theme": "^1.1.2",
    "typedoc-plugin-to-skills": "^0.6.0",
    "vue": "^3.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "author": "Pradeep Mouli <pmouli@mac.com> (https://github.com/pradeepmouli)"
}
