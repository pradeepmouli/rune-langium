# ─────────────────────────────────────────────────────────────────────────────
# Studio environment variables (014-studio-prod-ready / contracts/studio-config.md)
#
# Copy this file to `.env.local` and uncomment the lines you want to override.
# Defaults are baked into `apps/studio/src/config.ts`; `.env.local` only needs
# the values you change.
# ─────────────────────────────────────────────────────────────────────────────

# LSP host base URL. Studio appends `/ws/<sessionToken>` at runtime.
#   dev default:  ws://localhost:3001
#   prod default: wss://www.daikonic.dev/rune-studio/api/lsp
# VITE_LSP_WS_URL=ws://localhost:3001

# HTTP endpoint for `POST /lsp/session` (token mint).
# When unset, this is derived from VITE_LSP_WS_URL by swapping the scheme
# (ws → http, wss → https) and replacing the trailing `/lsp` with `/lsp/session`.
# VITE_LSP_SESSION_URL=http://localhost:3001/lsp/session

# Telemetry POST endpoint.
# When unset, defaults to `${location.origin}/api/telemetry/v1/event`.
# VITE_TELEMETRY_ENDPOINT=http://localhost:5173/api/telemetry/v1/event

# Dev-mode toggle. When `true`, the status bar shows developer-only copy
# (e.g. "start the LSP server on ws://localhost:3001"). Defaults to the
# value of `import.meta.env.DEV`.
# VITE_DEV_MODE=true

# Legacy isomorphic-git clone path (FR-019). Production builds default
# to `false`; flip to `true` only when locally testing the legacy fallback.
# VITE_LEGACY_GIT_PATH=false
