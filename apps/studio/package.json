{
  "name": "@rune-langium/studio",
  "version": "0.3.0",
  "private": true,
  "description": "Standalone web application for visual editing of Rune DSL models",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "bundle-size": "node scripts/check-bundle-size.mjs",
    "check-env": "node scripts/check-env.mjs",
    "clean": "rm -rf dist",
    "predev": "pnpm dev:cleanup",
    "dev": "vite",
    "dev:pages": "wrangler pages dev --proxy 5173 --port 8788 --compatibility-date 2025-09-23 --compatibility-flags nodejs_compat",
    "dev:cleanup": "sh scripts/dev-cleanup.sh",
    "predev:full": "pnpm dev:cleanup && pnpm build",
    "dev:full": "concurrently -k -n vite,lsp,mirror,pages -c blue,green,yellow,magenta \"pnpm dev\" \"pnpm --filter @rune-langium/lsp-worker dev\" \"pnpm --filter @rune-langium/curated-mirror-worker dev\" \"pnpm dev:pages\"",
    "lint": "oxlint .",
    "lint:css": "stylelint 'src/**/*.css'",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:prod-smoke": "PLAYWRIGHT_PROD_SMOKE=1 playwright test --config playwright.prod.config.ts",
    "type-check": "tsgo --noEmit && tsgo --noEmit -p functions/tsconfig.json"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.6",
    "@codemirror/lsp-client": "^6.2.4",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@hookform/resolvers": "^5.4.0",
    "@lezer/highlight": "^1.2.3",
    "@lspeasy/core": "^2.1.3",
    "@marsidev/react-turnstile": "^1.5.2",
    "@radix-ui/react-compose-refs": "1.1.2",
    "@radix-ui/react-primitive": "2.1.4",
    "@radix-ui/react-slot": "1.2.4",
    "@rune-langium/codegen": "workspace:*",
    "@rune-langium/codegen-legacy": "workspace:*",
    "@rune-langium/core": "workspace:*",
    "@rune-langium/curated-schema": "workspace:*",
    "@rune-langium/design-system": "workspace:*",
    "@rune-langium/git-sync-engine": "workspace:*",
    "@rune-langium/lsp-server": "workspace:*",
    "@rune-langium/visual-editor": "workspace:*",
    "@tanstack/react-virtual": "^3.13.25",
    "@xyflow/react": "^12.10.2",
    "buffer": "^6.0.3",
    "codemirror": "6.0.2",
    "dockview-react": "^6.5.0",
    "idb": "^8.0.3",
    "isomorphic-git": "^1.38.1",
    "jszip": "^3.10.1",
    "langium": "^4.2.4",
    "lucide-react": "^1.16.0",
    "pako": "^2.1.0",
    "pino": "^10.3.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "^7.76.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@cloudflare/workers-types": "^4.20260525.1",
    "@playwright/test": "1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/pako": "^2.0.4",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@zod-to-form/vite": "^0.4.1",
    "esbuild": "^0.28.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.7",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0",
    "wrangler": "^4.98.0"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "license": "FSL-1.1-ALv2",
  "author": "Pradeep Mouli <pmouli@mac.com> (https://github.com/pradeepmouli)"
}
