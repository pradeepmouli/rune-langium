{
  "name": "@rune-langium/studio",
  "version": "0.1.1",
  "private": true,
  "description": "Standalone web application for visual editing of Rune DSL models",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "check-env": "node scripts/check-env.mjs",
    "clean": "rm -rf dist",
    "dev": "vite",
    "dev:pages": "wrangler pages dev http://localhost:5173 --port 8788 --compatibility-date 2025-09-23 --compatibility-flags nodejs_compat",
    "lint": "oxlint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "type-check": "tsgo --noEmit && tsgo --noEmit -p functions/tsconfig.json"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.6",
    "@codemirror/lsp-client": "^6.2.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.42.1",
    "@hookform/resolvers": "^5.2.2",
    "@lezer/highlight": "^1.2.3",
    "@lspeasy/core": "^2.1.2",
    "@marsidev/react-turnstile": "^1.5.2",
    "@radix-ui/react-compose-refs": "1.1.2",
    "@radix-ui/react-primitive": "2.1.4",
    "@radix-ui/react-slot": "1.2.4",
    "@rune-langium/codegen": "workspace:*",
    "@rune-langium/codegen-legacy": "workspace:*",
    "@rune-langium/core": "workspace:*",
    "@rune-langium/curated-schema": "workspace:*",
    "@rune-langium/design-system": "workspace:*",
    "@rune-langium/lsp-server": "workspace:*",
    "@rune-langium/visual-editor": "workspace:*",
    "@tanstack/react-virtual": "^3.13.24",
    "@xyflow/react": "^12.10.2",
    "buffer": "^6.0.3",
    "codemirror": "6.0.2",
    "dockview-react": "^6.0.7",
    "idb": "^8.0.3",
    "isomorphic-git": "^1.37.6",
    "langium": "^4.2.3",
    "lucide-react": "^1.14.0",
    "pako": "^2.1.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "^7.75.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@cloudflare/workers-types": "^4.20260511.1",
    "@playwright/test": "1.59.1",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/pako": "^2.0.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@zod-to-form/vite": "^0.4.1",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.5",
    "wrangler": "^4.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "FSL-1.1-ALv2",
  "author": "Pradeep Mouli <pmouli@mac.com> (https://github.com/pradeepmouli)"
}
