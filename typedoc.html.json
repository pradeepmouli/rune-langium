{
  "$schema": "https://typedoc.org/schema.json",
  "out": "./docs",
  "plugin": ["typedoc-plugin-to-skills"],
  "skipErrorChecking": true,
  "excludePrivate": true,
  "excludeInternal": true,
  "readme": "README.md",
  "hideGenerator": false,
  "includeVersion": true,
  "treatWarningsAsErrors": false,
  "entryPointStrategy": "packages",
  "entryPoints": ["packages/*"]
}
